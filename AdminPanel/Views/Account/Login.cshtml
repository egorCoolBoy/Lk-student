@model WebApplication1.Models.VIewModels.LoginModel
@{
    ViewData["Title"] = "Вход";
}
@if (ViewBag.Error != null)
{
    <div style="color: red">
        @ViewBag.Error
    </div>
}
<form asp-action="Login" method="post">

    <div>
        <label>Login</label>
        <input asp-for="Email" />
    </div>

    <div>
        <label>Password</label>
        <input asp-for="Password"
               type="password"/>
    </div>

    <button type="submit">
        Login
    </button>

</form>